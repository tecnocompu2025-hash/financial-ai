{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": [
    "src/components/dashboard/AssetManagerV5.tsx",
    "src/components/dashboard/CreditEditor.tsx",
    "src/components/dashboard/CreditManager.tsx",
    "src/components/dashboard/CreditManagerV2.tsx",
    "src/components/dashboard/DebtHub.tsx",
    "src/components/dashboard/ExpenseManagerV5.tsx",
    "src/components/dashboard/GoalManagerCategories.tsx",
    "src/components/dashboard/GoalManagerV2.tsx",
    "src/components/dashboard/IncomeManagerV5.tsx",
    "src/components/dashboard/LiabilityManagerV5.tsx",
    "src/components/dashboard/MortgageManager.tsx",
    "src/components/dashboard/PaymentsHub.tsx",
    "src/components/dashboard/PaymentsHubV2.tsx",
    "src/components/dashboard/ReportManager.tsx"
  ]
}
